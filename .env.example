# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Firebase service-account key for GKM Firestore reporting.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line (remove all newlines).
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Unique ID for this kiosk — must be different on every Pi.
# Used as the Firestore document ID: /kiosks/{GKM_KIOSK_ID}
GKM_KIOSK_ID='kiosk-001'

# Display name shown in the GKM dashboard.
GKM_KIOSK_NAME='My Location Name'

# Location shown in the GKM dashboard.
GKM_KIOSK_LOCATION='City, State'

# Square credentials — only needed when going live. Leave blank to use the mock client.
# Get from: developer.squareup.com → Applications → Credentials
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_DEVICE_ID=
# "sandbox" or "production"
SQUARE_ENVIRONMENT=sandbox

# Firebase Storage bucket for camera snapshots (omit gs://).
# Found in: Firebase Console → Storage → default bucket name.
GKM_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# How often to capture and upload a camera snapshot (minutes). 0 = disabled.
GKM_SNAPSHOT_INTERVAL_MIN=0
